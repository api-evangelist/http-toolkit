  "request": {
    "method": "POST",
    "url": "http://localhost:45456/interceptors/fresh-chrome/activate/8000",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "result": {
        "success": true,
        "metadata": {
          "port": 8000
        }
      }
    }
  }
}
